COMPOSE_PROJECT_NAME=feelyoga
TZ=Europe/Moscow

MARIADB_VERSION=11

NGINX_VERSION=1.25
# NGINX_HOST/PORT не используются — ports сброшены в docker-compose.override.yml
# (nginx-proxy подключается к feelyoga-nginx через docker network)
NGINX_HOST=127.0.0.1
NGINX_PORT=8081

PHP_VERSION=8.4
PHP_XDEBUG=0

NODE_VERSION=24
NODE_PORT=3000

REDIS_VERSION=7

###

SITE_NAME="FeelYoga"
SITE_URL=https://feelyoga-dev.vaibkod.online/
API_URL=/api/

CORS=1
LOCALES=ru

# Скрыть все правые виджеты (один автор + наши блоки на главной заменяют их)
HIDE_WIDGETS=author,search,online,levels,categories,tags,pages

DB_DRIVER=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_PREFIX=app_
DB_DATABASE=vesp
DB_USERNAME=vesp
DB_PASSWORD=<сгенерировать: openssl rand -base64 24 | tr -d /+= | head -c 32>
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_general_ci
DB_FOREIGN_KEYS=1

SOCKET_SECRET=<сгенерировать: openssl rand -base64 32 | tr -d /+= | head -c 40>

JWT_SECRET=<сгенерировать: openssl rand -base64 48 | tr -d /+= | head -c 64>
JWT_EXPIRE=2592000
JWT_MAX=3

# SMTP — VK Workspace через ящик noreply@<domain> (создаётся в VK admin после verify).
# App-password — 16-символьный код из https://account.mail.ru/user/2-step-auth/passwords
# (логин под этим ящиком), а НЕ обычный пароль ящика. Пробелы убрать.
# См. reference_mail_ru_smtp_app_password.md в глобальной памяти.
SMTP_HOST=smtp.mail.ru
SMTP_USER=noreply@<DOMAIN>
SMTP_USER_NAME=<SITE_NAME>
SMTP_PASS=<16-char-app-password>
SMTP_PORT=587
SMTP_PROTO=tls

# (опционально, если SMTP-провайдер требует login≠from-адрес — например UniSender Go)
# Mail.php в нашем overlay поддерживает: setFrom(SMTP_FROM ?: SMTP_USER, ...)
# Для VK SMTP не требуется.
# SMTP_FROM=noreply@<DOMAIN>

UPLOAD_DIR=/vesp/upload/
CACHE_DIR=/vesp/tmp/
LOG_DIR=/vesp/log/
TEMPLATE_DIR=/vesp/core/templates/

LOG_ENABLED=1
LOG_LEVEL=error

# Timeweb Cloud S3 (РФ-резидент, бакет vaibkod-secure шарится между momarus/feelyoga/petparking).
# Изоляция проектов через S3_LOCATION префикс (см. overlay core/src/Services/CloudStorage.php).
# Включить когда у Михаила появятся первые видео и Денис подключит ключи в .env на VPS.
S3_ENABLED=0
# S3_KEY=<access key vaibkod-secure-app>
# S3_SECRET=<secret key>
# S3_ENDPOINT=https://s3.twcstorage.ru
# S3_BUCKET=vaibkod-secure
# S3_REGION=ru-1
# S3_OPTIONS={"use_path_style_endpoint":true}
# S3_LOCATION=feelyoga/                       — наш префикс для изоляции
# STREAM_MEDIA_FROM_S3=1                       — отдавать видео через presigned URL
# DOWNLOAD_MEDIA_FROM_S3=1                     — download attachments через presigned
# DOWNLOAD_MEDIA_FROM_S3_TIMEOUT=+1 hour       — TTL presigned

CACHE_S3_SIZE=0
CACHE_MEDIA_ACCESS_TIME=3600
CACHE_PAGES_TIME=0
CACHE_API_TIME=0
CACHE_API_TIME_USER=0
IMAGE_DRIVER=imagick

TRANSCODE_PRESET=fast
TRANSCODE_CHUNK=10
TRANSCODE_SET=426x240x256,854x480x1024,1280x720x2048,1920x1080x4096,3840x2160x10240

REGISTER_ENABLED=1
REGISTER_ROLE_ID=3
# Ссылка на страницу политики обработки персданных. Если задано — на форме
# регистрации появляется чекбокс согласия, серверный гард не пускает без agree=true
# (см. core/src/Controllers/Security/Register.php). ФЗ-152 требование.
REGISTER_USER_AGREEMENT=/pages/privacy

# Sentry/GlitchTip (self-hosted на том же VPS, errors.infra.vaibkod.online).
# DSN — выдаёт GlitchTip UI при создании проекта. PII принудительно выключен
# в bootstrap.php overlay (ФЗ-152: не отправляем IP/email пользователей в error tracker).
SENTRY_DSN=
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Yandex SmartCaptcha (ФЗ-152, заменяет Cloudflare Turnstile)
# Ключи получаются в Yandex Cloud Console → SmartCaptcha (аккаунт Михаила).
# SITE_KEY — для widget на фронте (есть в bundle, не секрет).
# SECRET — для серверной верификации в Register.php (см. core/src/Services/YandexCaptcha.php).
# Если оба пустые → captcha проверка пропускается (dev mode).
YANDEX_CAPTCHA_SITE_KEY=
NUXT_PUBLIC_YANDEX_CAPTCHA_SITE_KEY=
YANDEX_CAPTCHA_SECRET=

DOWNLOAD_MEDIA_ENABLED=0
DOWNLOAD_MEDIA_FROM_S3=0
EXTRACT_VIDEO_AUDIO_ENABLED=0
EXTRACT_VIDEO_THUMBNAILS_ENABLED=1
STREAM_MEDIA_FROM_S3=0

CLEAR_INACTIVE_USERS=3
CLEAR_USER_NOTIFICATIONS=10
CLEAR_TEMPORARY_FILES=3
CLEAR_FAILED_PAYMENTS=0
CLEAR_UNPAID_SUBSCRIPTIONS=0

ADMIN_SECTIONS=""

# EditorJS блоки в админке Заметок и Комментариев.
# КРИТИЧНО: пустая строка = НИКАКИХ блоков (counter-intuitive Orbita default).
# forms/topic.vue делает: editorBlocks = EDITOR_TOPIC_BLOCKS || false → boolean false → toolbar пустой.
# Указывать явно. paragraph всегда доступен и не перечисляется.
EDITOR_TOPIC_BLOCKS=header,list,image,video,audio,file,embed,code,kbd
EDITOR_COMMENT_BLOCKS=image,code,kbd

# Tbank payment gateway — интернет-эквайринг от Т-Банка Бизнес.
# Webhook endpoint: POST /api/web/payment/tbank (см. overlay routes.php +
# core/src/Controllers/Web/Payments/Tbank.php).
#
# Где брать ключи (для Михаила):
#   1. ЛК Т-Банка Бизнес → Эквайринг → Интернет-эквайринг → Создать магазин
#   2. После создания: вкладка «Реквизиты» → TerminalKey (~12 цифр) и Password
#   3. Тестовые ключи выдаются сразу. Боевые — после прохождения тестов и модерации Т-Банком.
#
# Тестовый режим: PAYMENT_TBANK_ENDPOINT=https://rest-api-test.tinkoff.ru/v2/
# Боевой режим: PAYMENT_TBANK_ENDPOINT=  (пусто = securepay.tinkoff.ru/v2/ по умолчанию)
#
# В админке Т-Банка → Магазины → Настройки уведомлений:
#   URL: https://filippov.yoga/api/web/payment/tbank
#   Метод: POST, формат JSON, версия v2
PAYMENT_SERVICES=Tbank
PAYMENT_SUBSCRIPTIONS=Tbank
PAYMENT_TBANK_TERMINAL=
PAYMENT_TBANK_PASSWORD=
PAYMENT_TBANK_ENDPOINT=
# Налоговый режим ИП (для чека-ФЗ-54). Варианты:
#   osn  — общая система налогообложения
#   usn_income  — УСН Доходы (наиболее частый у ИП-Михаила скорее всего)
#   usn_income_outcome  — УСН Доходы минус расходы
#   envd  — единый налог на вменённый доход (устарел)
#   esn  — единый сельхозналог
#   patent  — патентная система
PAYMENT_TBANK_TAXATION=usn_income
# Ставка НДС для позиций чека. Для ИП на УСН обычно vat_none / vat0.
# vat0 = ставка 0%, vat10 = 10%, vat20 = 20%, vat_none = без НДС.
PAYMENT_TBANK_RECEIPT_TAX=vat0

# Discount-map подписки. Format: "period_months:multiplier" через запятую.
# Применяется в App\Services\SubscriptionPricing и на фронте payment/subscription.vue.
# Пусто = без скидок (поведение как в upstream Orbita: amount = price × period).
# Пример: 1мес = full, 3мес = -5%, 6мес = -10%, 12мес = -25% (под Михаилов кейс 2000₽/мес → 18000₽/год)
SUBSCRIPTION_DISCOUNTS=1:1.0,3:0.95,6:0.90,12:0.75
